{
  "name": "next-ts-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "404": "cp out/404/index.html out/404.html",
    "test": "jest --passWithNoTests",
    "dev": "next dev --turbopack",
    "prebuild": "pnpm install",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "clean": "rimraf build",
    "pretest": "pnpm build",
    "all": "pnpm install && pnpm lint && pnpm test",
    "postbuild": "pnpm 404",
    "post404": "cp public/favicon.ico out",
    "prestyle-check": "pnpm install",
    "preformat": "pnpm install",
    "serve": "http-server out -p 8080"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^7.3.10",
    "i18next": "^25.10.10",
    "next": "^16.2.9",
    "next-i18next": "^16.0.7",
    "next-language-detector": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.6.6",
    "web-vitals": "^3.5.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@mui/icons-material": "^7.3.11",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-promise": "^7.3.0",
    "http-server": "^14.1.1",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "styled-jsx": "^5.1.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
